generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CallAnalysis {
  id                 String   @id @default(uuid())
  repName            String
  accountName        String
  dealStage          String
  overallRiskScore   Float
  meddicCompleteness Int
  rawTranscript      String   @db.Text
  meddicData         Json     // Storing the complex AI extraction
  objectionsData     Json     // Storing the array of objections
  createdAt          DateTime @default(now())
}